.codex
.env
.dev
bin/

# Frontend artifacts
web/node_modules/
web/dist/
web/coverage/

# TypeScript build info
*.tsbuildinfo

# Local-only operator secrets. Track only guard/template files; never real values.
/secret/*
!/secret/.gitignore
!/secret/README.md
!/secret/*.example
# .claude：忽略本地内容（settings.local.json / .DS_Store / shell / worktrees 等），
# 仅保留 .claude/skills 共享技能（AGENTS.md 引用，需随仓库追踪）。
.claude/*
!.claude/skills/

# Python bytecode
__pycache__/
*.pyc
