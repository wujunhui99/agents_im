syntax = "v1"

info (
	title:   "Friends API"
	desc:    "Friendship service HTTP API"
	author:  "Codex"
	version: "v0.1.0"
)

type FriendProfile {
	UserID        string `json:"user_id"`
	Identifier    string `json:"identifier"`
	DisplayName   string `json:"display_name"`
	Name          string `json:"name"`
	Gender        string `json:"gender"`
	BirthDate     string `json:"birth_date"`
	Region        string `json:"region"`
	AccountType   string `json:"account_type"`
	AvatarMediaID string `json:"avatar_media_id"`
	CreatedAt     string `json:"created_at"`
	UpdatedAt     string `json:"updated_at"`
}

type Friendship {
	UserID    string        `json:"user_id"`
	FriendID  string        `json:"friend_id"`
	Status    string        `json:"status"`
	IsFriend  bool          `json:"is_friend"`
	Friend    FriendProfile `json:"friend,optional"`
	CreatedAt string        `json:"created_at"`
	UpdatedAt string        `json:"updated_at"`
}

type AddFriendReq {
	UserID string `json:"user_id"`
}

type ListFriendsReq {
}

type ListFriendRequestsReq {
}

type FriendPathReq {
	UserID string `path:"user_id"`
}

type AddFriendData {
	Friendship Friendship `json:"friendship"`
	Created    bool       `json:"created"`
}

type DeleteFriendData {
	Friendship Friendship `json:"friendship"`
	Deleted    bool       `json:"deleted"`
}

type AcceptFriendData {
	Friendship Friendship `json:"friendship"`
	Accepted   bool       `json:"accepted"`
}

type RejectFriendData {
	Friendship Friendship `json:"friendship"`
	Rejected   bool       `json:"rejected"`
}

type ListFriendsData {
	Friends []Friendship `json:"friends"`
}

type ListFriendRequestsData {
	Incoming []Friendship `json:"incoming"`
	Outgoing []Friendship `json:"outgoing"`
}

type FriendshipData {
	Friendship Friendship `json:"friendship"`
}

type AddFriendResp {
	Code    string        `json:"code"`
	Message string        `json:"message"`
	Data    AddFriendData `json:"data"`
}

type DeleteFriendResp {
	Code    string           `json:"code"`
	Message string           `json:"message"`
	Data    DeleteFriendData `json:"data"`
}

type AcceptFriendResp {
	Code    string           `json:"code"`
	Message string           `json:"message"`
	Data    AcceptFriendData `json:"data"`
}

type RejectFriendResp {
	Code    string           `json:"code"`
	Message string           `json:"message"`
	Data    RejectFriendData `json:"data"`
}

type ListFriendsResp {
	Code    string          `json:"code"`
	Message string          `json:"message"`
	Data    ListFriendsData `json:"data"`
}

type ListFriendRequestsResp {
	Code    string                 `json:"code"`
	Message string                 `json:"message"`
	Data    ListFriendRequestsData `json:"data"`
}

type FriendshipResp {
	Code    string         `json:"code"`
	Message string         `json:"message"`
	Data    FriendshipData `json:"data"`
}

@server (
	jwt:   Auth
	group: friends
)
service friends-api {
	@handler addFriend
	post /friends (AddFriendReq) returns (AddFriendResp)

	@handler listFriends
	get /friends (ListFriendsReq) returns (ListFriendsResp)

	@handler listFriendRequests
	get /friends/requests (ListFriendRequestsReq) returns (ListFriendRequestsResp)

	@handler acceptFriend
	post /friends/:user_id/accept (FriendPathReq) returns (AcceptFriendResp)

	@handler rejectFriend
	post /friends/:user_id/reject (FriendPathReq) returns (RejectFriendResp)

	@handler deleteFriend
	delete /friends/:user_id (FriendPathReq) returns (DeleteFriendResp)

	@handler getFriendship
	get /friends/:user_id (FriendPathReq) returns (FriendshipResp)
}
