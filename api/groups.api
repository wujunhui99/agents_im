syntax = "v1"

info (
	title:   "Groups API"
	desc:    "Group profile and membership service HTTP API"
	author:  "Codex"
	version: "v0.1.0"
)

type Group {
	GroupID       string `json:"group_id"`
	Name          string `json:"name"`
	Description   string `json:"description"`
	CreatorUserID string `json:"creator_user_id"`
	CreatedAt     string `json:"created_at"`
	UpdatedAt     string `json:"updated_at"`
}

type GroupMember {
	GroupID       string `json:"group_id"`
	UserID        string `json:"user_id"`
	State         string `json:"state"`
	JoinedAt      string `json:"joined_at"`
	LeftAt        string `json:"left_at"`
	Identifier    string `json:"identifier,optional"`
	DisplayName   string `json:"display_name,optional"`
	Name          string `json:"name,optional"`
	AvatarMediaID string `json:"avatar_media_id,optional"`
}

type CreateGroupReq {
	Name          string   `json:"name"`
	Description   string   `json:"description,optional"`
	MemberUserIDs []string `json:"member_user_ids,optional"`
}

type GetGroupReq {
	GroupID string `path:"group_id"`
}

type ListGroupsReq {}

type AddMemberReq {
	GroupID string `path:"group_id"`
	UserID  string `json:"user_id,optional"`
}

type LeaveGroupReq {
	GroupID string `path:"group_id"`
}

type ListMembersReq {
	GroupID string `path:"group_id"`
}

type GroupResp {
	Code    string `json:"code"`
	Message string `json:"message"`
	Data    Group  `json:"data"`
}

type MemberData {
	Member        GroupMember `json:"member"`
	AlreadyMember bool        `json:"already_member"`
}

type MemberResp {
	Code    string     `json:"code"`
	Message string     `json:"message"`
	Data    MemberData `json:"data"`
}

type ListMembersData {
	GroupID string        `json:"group_id"`
	Members []GroupMember `json:"members"`
}

type ListMembersResp {
	Code    string          `json:"code"`
	Message string          `json:"message"`
	Data    ListMembersData `json:"data"`
}

type ListGroupsData {
	Groups []Group `json:"groups"`
}

type ListGroupsResp {
	Code    string         `json:"code"`
	Message string         `json:"message"`
	Data    ListGroupsData `json:"data"`
}

@server (
	jwt:   Auth
	group: groups
)
service groups-api {
	@handler createGroup
	post /groups (CreateGroupReq) returns (GroupResp)

	@handler listGroups
	get /groups (ListGroupsReq) returns (ListGroupsResp)

	@handler addMember
	post /groups/:group_id/members (AddMemberReq) returns (MemberResp)

	@handler leaveGroup
	delete /groups/:group_id/members/me (LeaveGroupReq) returns (MemberResp)

	@handler getGroup
	get /groups/:group_id (GetGroupReq) returns (GroupResp)

	@handler listMembers
	get /groups/:group_id/members (ListMembersReq) returns (ListMembersResp)
}
