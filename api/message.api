syntax = "v1"

info (
	title:   "Message API"
	desc:    "Message service phase 1 HTTP API"
	author:  "Codex"
	version: "v0.1.0"
)

type Message {
	ServerMsgID    string `json:"serverMsgId"`
	ClientMsgID    string `json:"clientMsgId"`
	ConversationID string `json:"conversationId"`
	Seq            int64  `json:"seq"`
	SenderID       string `json:"senderId"`
	ReceiverID     string `json:"receiverId"`
	GroupID        string `json:"groupId"`
	ChatType       string `json:"chatType"`
	ContentType    string `json:"contentType"`
	Content        string `json:"content"`
	SendTime       int64  `json:"sendTime"`
	CreatedAt      int64  `json:"createdAt"`
}

type SendMessageReq {
	CurrentUserID string `header:"X-User-Id"`
	ReceiverID    string `json:"receiverId,optional"`
	GroupID       string `json:"groupId,optional"`
	ChatType      string `json:"chatType"`
	ClientMsgID   string `json:"clientMsgId"`
	ContentType   string `json:"contentType"`
	Content       string `json:"content"`
}

type SendMessageData {
	Message      Message `json:"message"`
	Deduplicated bool    `json:"deduplicated"`
}

type SendMessageResp {
	Code    string          `json:"code"`
	Message string          `json:"message"`
	Data    SendMessageData `json:"data"`
}

type PullMessagesReq {
	CurrentUserID  string `header:"X-User-Id"`
	ConversationID string `path:"conversation_id"`
	FromSeq        int64  `form:"fromSeq,optional"`
	ToSeq          int64  `form:"toSeq,optional"`
	Limit          int64  `form:"limit,optional"`
	Order          string `form:"order,optional"`
}

type PullMessagesData {
	Messages []Message `json:"messages"`
	IsEnd    bool      `json:"isEnd"`
	NextSeq  int64     `json:"nextSeq"`
}

type PullMessagesResp {
	Code    string           `json:"code"`
	Message string           `json:"message"`
	Data    PullMessagesData `json:"data"`
}

type ConversationSeqsReq {
	CurrentUserID   string `header:"X-User-Id"`
	ConversationIDs string `form:"conversationIds,optional"`
}

type ConversationSeqState {
	ConversationID string  `json:"conversationId"`
	MaxSeq         int64   `json:"maxSeq"`
	HasReadSeq     int64   `json:"hasReadSeq"`
	UnreadCount    int64   `json:"unreadCount"`
	MaxSeqTime     int64   `json:"maxSeqTime"`
	LastMessage    Message `json:"lastMessage,omitempty"`
}

type ConversationSeqsData {
	States []ConversationSeqState `json:"states"`
}

type ConversationSeqsResp {
	Code    string               `json:"code"`
	Message string               `json:"message"`
	Data    ConversationSeqsData `json:"data"`
}

type MarkConversationAsReadReq {
	CurrentUserID  string `header:"X-User-Id"`
	ConversationID string `path:"conversation_id"`
	HasReadSeq     int64  `json:"hasReadSeq"`
}

type MarkConversationAsReadData {
	ConversationID string `json:"conversationId"`
	HasReadSeq     int64  `json:"hasReadSeq"`
	MaxSeq         int64  `json:"maxSeq"`
	UnreadCount    int64  `json:"unreadCount"`
	Updated        bool   `json:"updated"`
}

type MarkConversationAsReadResp {
	Code    string                     `json:"code"`
	Message string                     `json:"message"`
	Data    MarkConversationAsReadData `json:"data"`
}

@server (
	group: message
)
service message-api {
	@handler sendMessage
	post /messages (SendMessageReq) returns (SendMessageResp)

	@handler pullMessages
	get /conversations/:conversation_id/messages (PullMessagesReq) returns (PullMessagesResp)

	@handler getConversationSeqs
	get /conversations/seqs (ConversationSeqsReq) returns (ConversationSeqsResp)

	@handler markConversationAsRead
	post /conversations/:conversation_id/read (MarkConversationAsReadReq) returns (MarkConversationAsReadResp)
}
