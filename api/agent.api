syntax = "v1"

info (
	title:   "Agent API"
	desc:    "Agent management foundation HTTP API; im_user_id is a V0 alias for an agent account_id."
	author:  "Codex"
	version: "v0.1.0"
)

type Agent {
	AgentID     string `json:"agent_id"`
	IMUserID    string `json:"im_user_id"`
	Name        string `json:"name"`
	Description string `json:"description"`
	Status      string `json:"status"`
	CreatedBy   string `json:"created_by"`
	CreatedAt   string `json:"created_at"`
	UpdatedAt   string `json:"updated_at"`
}

type CreateAgentReq {
	IMUserID    string `json:"im_user_id"`
	Name        string `json:"name"`
	Description string `json:"description,optional"`
	Status      string `json:"status,optional"`
}

type UpdateAgentReq {
	AgentID     string `path:"agent_id"`
	Name        string `json:"name,optional"`
	Description string `json:"description,optional"`
}

type UpdateAgentStatusReq {
	AgentID string `path:"agent_id"`
	Status  string `json:"status"`
}

type AgentPathReq {
	AgentID string `path:"agent_id"`
}

type AgentDefinitionPrompt {
	PromptID            string `json:"prompt_id"`
	Name                string `json:"name"`
	Description         string `json:"description"`
	Content             string `json:"content"`
	VariablesSchemaJSON string `json:"variables_schema_json"`
	Version             string `json:"version"`
	Status              string `json:"status"`
	CreatedBy           string `json:"created_by"`
	CreatedAt           string `json:"created_at"`
	UpdatedAt           string `json:"updated_at"`
}

type AgentDefinitionTool {
	ToolID           string `json:"tool_id"`
	Name             string `json:"name"`
	Description      string `json:"description"`
	ToolType         string `json:"tool_type"`
	MCPServerID      string `json:"mcp_server_id,omitempty"`
	MCPToolName      string `json:"mcp_tool_name,omitempty"`
	LocalHandlerKey  string `json:"local_handler_key,omitempty"`
	BuiltinKey       string `json:"builtin_key,omitempty"`
	InputSchemaJSON  string `json:"input_schema_json"`
	OutputSchemaJSON string `json:"output_schema_json"`
	PermissionLevel  string `json:"permission_level"`
	Status           string `json:"status"`
	AdminConfigured  bool   `json:"admin_configured"`
}

type AgentDefinitionData {
	Agent        Agent                 `json:"agent"`
	SystemPrompt AgentDefinitionPrompt `json:"system_prompt"`
	Tools        []AgentDefinitionTool `json:"tools"`
}

type UpdateAgentDefinitionReq {
	AgentID      string   `path:"agent_id"`
	SystemPrompt string   `json:"system_prompt"`
	ToolNames    []string `json:"tool_names,optional"`
}

type ListAgentsReq {
	Status    string `form:"status,optional"`
	CreatedBy string `form:"created_by,optional"`
	Limit     int64  `form:"limit,optional"`
	Offset    int64  `form:"offset,optional"`
}

type AgentResp {
	Code    string `json:"code"`
	Message string `json:"message"`
	Data    Agent  `json:"data"`
}

type AgentDefinitionResp {
	Code    string              `json:"code"`
	Message string              `json:"message"`
	Data    AgentDefinitionData `json:"data"`
}

type ListAgentsData {
	Agents []Agent `json:"agents"`
}

type ListAgentsResp {
	Code    string         `json:"code"`
	Message string         `json:"message"`
	Data    ListAgentsData `json:"data"`
}

@server (
	jwt:   Auth
	group: agent
)
service agent-api {
	@handler createAgent
	post /agents (CreateAgentReq) returns (AgentResp)

	@handler listAgents
	get /agents (ListAgentsReq) returns (ListAgentsResp)

	@handler getAgent
	get /agents/:agent_id (AgentPathReq) returns (AgentResp)

	@handler getAgentDefinition
	get /agents/:agent_id/definition (AgentPathReq) returns (AgentDefinitionResp)

	@handler updateAgentDefinition
	put /agents/:agent_id/definition (UpdateAgentDefinitionReq) returns (AgentDefinitionResp)

	@handler updateAgent
	patch /agents/:agent_id (UpdateAgentReq) returns (AgentResp)

	@handler updateAgentStatus
	patch /agents/:agent_id/status (UpdateAgentStatusReq) returns (AgentResp)

	@handler deleteAgent
	delete /agents/:agent_id (AgentPathReq) returns (AgentResp)
}
