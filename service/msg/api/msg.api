syntax = "v1"

info (
	title:   "Msg API"
	desc:    "消息域 HTTP BFF——承接原 message-api 全部路由：4 条消息路由 + AI 托管开关经 gRPC 调 msg-rpc，feedback 经 gRPC 调 admin-rpc（07-message-rpc-redesign / issue #463）"
	author:  "claude"
	version: "v0.2.0"
)

type Message {
	ServerMsgID           string `json:"serverMsgId"`
	ClientMsgID           string `json:"clientMsgId"`
	ConversationID        string `json:"conversationId"`
	Seq                   int64  `json:"seq"`
	SenderID              string `json:"senderId"`
	ReceiverID            string `json:"receiverId"`
	GroupID               string `json:"groupId"`
	ChatType              string `json:"chatType"`
	ContentType           string `json:"contentType"`
	Content               string `json:"content"`
	MessageOrigin         string `json:"messageOrigin"`
	AgentAccountID        string `json:"agentAccountId,optional"`
	TriggerServerMsgID    string `json:"triggerServerMsgId,optional"`
	AgentRunID            string `json:"agentRunId,optional"`
	AllowRecursiveTrigger bool   `json:"allowRecursiveTrigger,optional"`
	SendTime              int64  `json:"sendTime"`
	CreatedAt             int64  `json:"createdAt"`
}

type ConversationSeqState {
	ConversationID string   `json:"conversationId"`
	MaxSeq         int64    `json:"maxSeq"`
	HasReadSeq     int64    `json:"hasReadSeq"`
	UnreadCount    int64    `json:"unreadCount"`
	MaxSeqTime     int64    `json:"maxSeqTime"`
	LastMessage    *Message `json:"lastMessage,omitempty"`
}

// ---- SendMessage ----
type SendMessageReq {
	SenderID              string `json:"senderId,optional"`
	ReceiverID            string `json:"receiverId,optional"`
	GroupID               string `json:"groupId,optional"`
	ChatType              string `json:"chatType"`
	ClientMsgID           string `json:"clientMsgId"`
	ContentType           string `json:"contentType"`
	Content               string `json:"content"`
	MessageOrigin         string `json:"messageOrigin,optional"`
	AgentAccountID        string `json:"agentAccountId,optional"`
	TriggerServerMsgID    string `json:"triggerServerMsgId,optional"`
	AgentRunID            string `json:"agentRunId,optional"`
	AllowRecursiveTrigger bool   `json:"allowRecursiveTrigger,optional"`
}

type SendMessageData {
	Message      Message `json:"message"`
	Deduplicated bool    `json:"deduplicated"`
}

type SendMessageResp {
	Code    string          `json:"code"`
	Message string          `json:"message"`
	Data    SendMessageData `json:"data"`
}

// ---- PullMessages ----
type PullMessagesReq {
	ConversationID string `path:"conversation_id"`
	FromSeq        int64  `form:"fromSeq,optional"`
	ToSeq          int64  `form:"toSeq,optional"`
	Limit          int64  `form:"limit,optional"`
	Order          string `form:"order,optional"`
}

type PullMessagesData {
	Messages []Message `json:"messages"`
	IsEnd    bool      `json:"isEnd"`
	NextSeq  int64     `json:"nextSeq"`
}

type PullMessagesResp {
	Code    string           `json:"code"`
	Message string           `json:"message"`
	Data    PullMessagesData `json:"data"`
}

// ---- GetConversationSeqs ----
type ConversationSeqsReq {
	ConversationIDs string `form:"conversationIds,optional"`
}

type ConversationSeqsData {
	States []ConversationSeqState `json:"states"`
}

type ConversationSeqsResp {
	Code    string               `json:"code"`
	Message string               `json:"message"`
	Data    ConversationSeqsData `json:"data"`
}

// ---- MarkConversationAsRead ----
type MarkConversationAsReadReq {
	ConversationID string `path:"conversation_id"`
	HasReadSeq     int64  `json:"hasReadSeq"`
}

type MarkConversationAsReadData {
	ConversationID string `json:"conversationId"`
	HasReadSeq     int64  `json:"hasReadSeq"`
	MaxSeq         int64  `json:"maxSeq"`
	UnreadCount    int64  `json:"unreadCount"`
	Updated        bool   `json:"updated"`
}

type MarkConversationAsReadResp {
	Code    string                     `json:"code"`
	Message string                     `json:"message"`
	Data    MarkConversationAsReadData `json:"data"`
}

// ---- ConversationAIHosting（BFF over msg-rpc）----
type ConversationAIHostingReq {
	ConversationID string `path:"conversation_id"`
}

type UpdateConversationAIHostingReq {
	ConversationID string `path:"conversation_id"`
	Enabled        bool   `json:"enabled"`
}

type ConversationAIHostingData {
	ConversationID    string `json:"conversationId"`
	ChatType          string `json:"chatType"`
	Enabled           bool   `json:"enabled"`
	Available         bool   `json:"available"`
	PeerEnabled       bool   `json:"peerEnabled"`
	UnavailableReason string `json:"unavailableReason,optional"`
	MaxRecentMessages int64  `json:"maxRecentMessages"`
	SummaryEnabled    bool   `json:"summaryEnabled"`
}

type ConversationAIHostingResp {
	Code    string                    `json:"code"`
	Message string                    `json:"message"`
	Data    ConversationAIHostingData `json:"data"`
}

// ---- CreateFeedback（BFF over admin-rpc）----
type CreateFeedbackReq {
	Category   string                 `json:"category"`
	Title      string                 `json:"title"`
	Content    string                 `json:"content"`
	Contact    string                 `json:"contact,optional"`
	PageURL    string                 `json:"pageUrl,optional"`
	UserAgent  string                 `json:"userAgent,optional"`
	ClientMeta map[string]interface{} `json:"clientMeta,optional"`
}

type FeedbackData {
	FeedbackID string `json:"feedbackId"`
	Status     string `json:"status"`
}

type CreateFeedbackResp {
	Code    string       `json:"code"`
	Message string       `json:"message"`
	Data    FeedbackData `json:"data"`
}

@server (
	jwt:        Auth
	middleware: DeviceAuth
	group:      msg
)
service msg-api {
	@handler sendMessage
	post /messages (SendMessageReq) returns (SendMessageResp)

	@handler pullMessages
	get /conversations/:conversation_id/messages (PullMessagesReq) returns (PullMessagesResp)

	@handler getConversationSeqs
	get /conversations/seqs (ConversationSeqsReq) returns (ConversationSeqsResp)

	@handler markConversationAsRead
	post /conversations/:conversation_id/read (MarkConversationAsReadReq) returns (MarkConversationAsReadResp)

	@handler getConversationAIHosting
	get /conversations/:conversation_id/ai-hosting (ConversationAIHostingReq) returns (ConversationAIHostingResp)

	@handler updateConversationAIHosting
	put /conversations/:conversation_id/ai-hosting (UpdateConversationAIHostingReq) returns (ConversationAIHostingResp)

	@handler createFeedback
	post /api/feedback (CreateFeedbackReq) returns (CreateFeedbackResp)
}

