# Local development PostgreSQL settings only.
# Do not reuse these values for production or shared environments.

POSTGRES_DB=agents_im
POSTGRES_USER=agents_im
POSTGRES_PASSWORD=agents_im_dev_password
POSTGRES_PORT=5432

# Local development Redis settings only.
# This password is a development placeholder for docker-compose, not a real secret.
REDIS_ADDR=localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=agents_im_redis_dev_password
REDIS_DB=0

# Local development Redpanda/Kafka-compatible broker settings only.
# Host processes should use localhost:19092; Docker services can use redpanda:9092.
REDPANDA_KAFKA_PORT=19092
REDPANDA_ADMIN_PORT=9644
KAFKA_BROKERS=localhost:19092
KAFKA_MESSAGE_EVENTS_TOPIC=message.events.v1
KAFKA_CONSUMER_GROUP=message-transfer-worker

# Local development MinIO / S3-compatible object storage settings.
# Console is bound by docker-compose at http://localhost:9001.
MINIO_ROOT_USER=agents_im_minio
MINIO_ROOT_PASSWORD=agents_im_minio_dev_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
OBJECT_STORAGE_DRIVER=minio
OBJECT_STORAGE_ENDPOINT=localhost:9000
OBJECT_STORAGE_EXTERNAL_ENDPOINT=localhost:9000
OBJECT_STORAGE_BUCKET=agents-im-media
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_USE_SSL=false
OBJECT_STORAGE_EXTERNAL_USE_SSL=false
OBJECT_STORAGE_ACCESS_KEY_ID=agents_im_minio
OBJECT_STORAGE_SECRET_ACCESS_KEY=agents_im_minio_dev_password

# Message Transfer exposes lightweight /healthz, /readyz, and /metrics when enabled.
MESSAGE_TRANSFER_CONSUMER_DRIVER=outbox
MESSAGE_TRANSFER_DISPATCHER_DRIVER=gateway
MESSAGE_TRANSFER_OBSERVABILITY_ENABLED=true
MESSAGE_TRANSFER_OBSERVABILITY_HOST=127.0.0.1
MESSAGE_TRANSFER_OBSERVABILITY_PORT=8087

# Presence defaults to memory so normal tests and local service starts do not
# require Redis. Set PRESENCE_DRIVER=redis when exercising Gateway presence.
PRESENCE_DRIVER=memory
PRESENCE_TTL_SECONDS=60
PRESENCE_KEY_PREFIX=agents_im:presence

# Gateway WebSocket local development settings.
# Production should set exact public origins. Enable query-token auth only for
# browser-native deployments that cannot send Authorization headers.
GATEWAY_WS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
GATEWAY_WS_ALLOW_QUERY_TOKEN=true
GATEWAY_WS_PING_INTERVAL_SECONDS=30
GATEWAY_WS_HEARTBEAT_TIMEOUT_SECONDS=75
GATEWAY_WS_COMMAND_RATE_LIMIT_PER_SECOND=20
GATEWAY_WS_COMMAND_RATE_LIMIT_BURST=40

# Services use memory repositories unless StorageDriver is set to postgres.
AGENTS_IM_STORAGE_DRIVER=postgres
DATABASE_URL=postgres://agents_im:agents_im_dev_password@localhost:5432/agents_im?sslmode=disable

# Host service ports used by scripts/dev-up.sh unless overridden.
AGENT_API_PORT=8086

# DeepSeek model settings for Agent runtime. Keep real keys only in local .env
# or secret storage; this example value is a placeholder.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=replace-with-local-deepseek-api-key

# LLM observability is disabled by default. Langfuse credentials are
# placeholders only; keep real values in local env or secret storage.
LLM_OBSERVABILITY_ENABLED=false
LLM_OBSERVABILITY_BACKEND=noop
LLM_OBSERVABILITY_CAPTURE_OUTPUT=false
LLM_OBSERVABILITY_MAX_OUTPUT_BYTES=2048
LANGFUSE_HOST=https://langfuse.agenticim.xyz
LANGFUSE_PUBLIC_KEY=replace-with-langfuse-public-key
LANGFUSE_SECRET_KEY=replace-with-langfuse-secret-key

# Tencent Cloud SES settings for the internal mail-rpc service. Keep real
# SecretId/SecretKey values only in local .env or secret storage.
TENCENT_SES_SECRET_ID=replace-with-tencent-ses-secret-id
TENCENT_SES_SECRET_KEY=replace-with-tencent-ses-secret-key
TENCENT_SES_REGION=ap-hongkong
TENCENT_SES_FROM_EMAIL=noreply@agenticim.xyz
TENCENT_SES_DEFAULT_TEMPLATE_ID=177952
