Name: media-api
Host: 127.0.0.1
Port: ${MEDIA_API_PORT}
Auth:
  AccessSecret: ${JWT_ACCESS_SECRET}
  AccessExpire: ${JWT_ACCESS_EXPIRE}
MediaRPC:
  Endpoints:
    - 127.0.0.1:${MEDIA_RPC_PORT}
  Timeout: 5000
MsgRPC:
  Endpoints:
    - 127.0.0.1:${MSG_RPC_PORT}
  Timeout: 5000
FriendsRPC:
  Endpoints:
    - 127.0.0.1:${FRIENDS_RPC_PORT}
  Timeout: 5000
GroupsRPC:
  Endpoints:
    - 127.0.0.1:${GROUPS_RPC_PORT}
  Timeout: 5000
Telemetry:
  Name: media-api
  Endpoint: 127.0.0.1:${TEMPO_OTLP_GRPC_PORT}
  Sampler: 1.0
  Batcher: otlpgrpc
