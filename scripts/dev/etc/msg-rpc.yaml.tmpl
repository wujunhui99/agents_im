Name: msg-rpc
ListenOn: 127.0.0.1:${MSG_RPC_PORT}
DataSource: ${DATABASE_URL}
Telemetry:
  Name: msg-rpc
  Endpoint: 127.0.0.1:${TEMPO_OTLP_GRPC_PORT}
  Sampler: 1.0
  Batcher: otlpgrpc
DeepSeek:
  APIKey: ${DEEPSEEK_API_KEY}
  BaseURL: ${DEEPSEEK_BASE_URL}
  Model: ${DEEPSEEK_MODEL}
PythonExecutor:
  Backend: disabled
UserRPC:
  Endpoints:
    - 127.0.0.1:${USER_RPC_PORT}
  Timeout: 5000
MediaRPC:
  Endpoints:
    - 127.0.0.1:${MEDIA_RPC_PORT}
  Timeout: 5000
Kafka:
  Enabled: true
  Brokers: ${KAFKA_BROKERS}
