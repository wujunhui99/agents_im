Name: auth-rpc
ListenOn: 127.0.0.1:${AUTH_RPC_PORT}
TokenAuth:
  AccessSecret: ${JWT_ACCESS_SECRET}
  AccessExpire: ${JWT_ACCESS_EXPIRE}
DataSource: ${DATABASE_URL}
SessionRedis:
  Addr: ${REDIS_ADDR}
  Password: ${REDIS_PASSWORD}
  DB: ${REDIS_DB}
MailRPC:
  Endpoints:
    - 127.0.0.1:${MAIL_RPC_PORT}
  Timeout: 5000
UserRPC:
  Endpoints:
    - 127.0.0.1:${USER_RPC_PORT}
  Timeout: 5000
Telemetry:
  Name: auth-rpc
  Endpoint: 127.0.0.1:${TEMPO_OTLP_GRPC_PORT}
  Sampler: 1.0
  Batcher: otlpgrpc
