Name: friends-api
Host: 127.0.0.1
Port: ${FRIENDS_API_PORT}
Auth:
  AccessSecret: ${JWT_ACCESS_SECRET}
  AccessExpire: ${JWT_ACCESS_EXPIRE}
StorageDriver: postgres
DataSource: ${DATABASE_URL}
Redis:
  Addr: ${REDIS_ADDR}
  Password: ${REDIS_PASSWORD}
  DB: ${REDIS_DB}
FriendsRPC:
  Endpoints:
    - 127.0.0.1:${FRIENDS_RPC_PORT}
  Timeout: 5000
UserRPC:
  Endpoints:
    - 127.0.0.1:${USER_RPC_PORT}
  Timeout: 5000
Telemetry:
  Name: friends-api
  Endpoint: 127.0.0.1:${TEMPO_OTLP_GRPC_PORT}
  Sampler: 1.0
  Batcher: otlpgrpc
