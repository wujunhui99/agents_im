Name: auth-api
Host: 127.0.0.1
Port: ${AUTH_API_PORT}
Auth:
  AccessSecret: ${JWT_ACCESS_SECRET}
  AccessExpire: ${JWT_ACCESS_EXPIRE}
AuthRPC:
  Endpoints:
    - 127.0.0.1:${AUTH_RPC_PORT}
  Timeout: 5000
Telemetry:
  Name: auth-api
  Endpoint: 127.0.0.1:${TEMPO_OTLP_GRPC_PORT}
  Sampler: 1.0
  Batcher: otlpgrpc
